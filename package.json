{
  "name": "harnesslintingtest",
  "version": "1.0.0",
  "description": "Simple Markdown linter prototype",
  "type": "module",
  "bin": {
    "markdown-lint": "./src/cli.ts"
  },
  "scripts": {
    "extension:build": "npm --prefix ./vscode-extension run compile",
    "extension:watch": "npm --prefix ./vscode-extension run watch",
    "extension:pack": "npm --prefix ./vscode-extension run pack",
    "extension:install-local": "node ./scripts/install-local-extension.mjs",
    "extension:dev": "node ./scripts/extension-dev.mjs",
    "postinstall": "npm --prefix ./vscode-extension install",
    "test": "vitest run",
    "lint:md": "node src/cli.ts"
  },
  "keywords": [
    "markdown",
    "linter",
    "typescript"
  ],
  "license": "ISC",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "yaml": "^2.8.4"
  }
}
