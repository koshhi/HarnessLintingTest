{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Extension: Build",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "extension:build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Extension: Watch",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "extension:watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Extension: Package VSIX",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "extension:pack"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Extension: Install Local",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "extension:install-local"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Markdown: Lint Current File",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint:md",
        "--",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Markdown: Lint Examples",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint:md",
        "--",
        "examples"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
