{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Markdown: Lint Current File",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint:md",
        "--",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Markdown: Lint Examples",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint:md",
        "--",
        "examples"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
